{{#quiz}}
<div class="quiz-block mb-4">
    <div class="quiz-question"><strong>{{question}}</strong></div>
    <ul class="quiz-options">
        {{#options}}
            <li>{{.}}</li>
        {{/options}}
    </ul>
</div>
{{/quiz}}
{{^quiz}}
<p><em>No quiz content available.</em></p>
{{/quiz}}

.quiz-block {
    background: #f8f9fa;
    padding: 12px;
    border-left: 4px solid #0069cc;
    margin-bottom: 15px;
    border-radius: 5px;
}
.quiz-question {
    margin-bottom: 6px;
}
.quiz-options {
    padding-left: 20px;
}
.quiz-options li {
    margin-bottom: 4px;
}

