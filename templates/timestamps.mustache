{{!
    Generation timestamps list for local_haccgen.

    @package     local_haccgen
    @copyright   2026 Dynamicpixel Multimedia Solutions
    @license     http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later
}}
<div class="local_haccgen-timestamps container-fluid">
    <div class="mb-3">
        <a href="{{manageurl}}" class="btn btn-secondary">{{#str}}manageai, local_haccgen{{/str}}</a>
    </div>
    <h3>{{#str}}timestamps_view_title, local_haccgen{{/str}}</h3>
    <p class="text-muted">{{coursename}}</p>

    {{#has_records}}
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>{{#str}}timestamps_saved_at, local_haccgen{{/str}}</th>
                    <th>{{#str}}timestamps_type, local_haccgen{{/str}}</th>
                    <th>{{#str}}timestamps_batchid, local_haccgen{{/str}}</th>
                    <th>{{#str}}timestamps_topics, local_haccgen{{/str}}</th>
                    <th>{{#str}}timestamps_topic_duration, local_haccgen{{/str}}</th>
                    <th>{{#str}}timestamps_topic_generated, local_haccgen{{/str}}</th>
                    <th>{{#str}}timestamps_content_duration, local_haccgen{{/str}}</th>
                    <th>{{#str}}timestamps_content_completed, local_haccgen{{/str}}</th>
                    <th>{{#str}}timestamps_user, local_haccgen{{/str}}</th>
                </tr>
            </thead>
            <tbody>
                {{#records}}
                <tr>
                    <td>{{saved_at}}</td>
                    <td><span class="badge {{badge_class}}">{{record_type_label}}</span></td>
                    <td>{{#batchid}}{{batchid}}{{/batchid}}{{^batchid}}—{{/batchid}}</td>
                    <td>{{#topic_summary}}{{topic_summary}}{{/topic_summary}}{{^topic_summary}}—{{/topic_summary}}</td>
                    <td>{{#topic_duration}}{{topic_duration}}{{/topic_duration}}{{^topic_duration}}—{{/topic_duration}}</td>
                    <td>{{#topic_generated_at}}{{topic_generated_at}}{{/topic_generated_at}}{{^topic_generated_at}}—{{/topic_generated_at}}</td>
                    <td>{{#content_duration}}{{content_duration}}{{/content_duration}}{{^content_duration}}—{{/content_duration}}</td>
                    <td>{{#content_completed_at}}{{content_completed_at}}{{/content_completed_at}}{{^content_completed_at}}—{{/content_completed_at}}</td>
                    <td>{{username}}</td>
                </tr>
                {{/records}}
            </tbody>
        </table>
    </div>
    {{/has_records}}
    {{^has_records}}
    <p class="alert alert-info">{{#str}}timestamps_no_records, local_haccgen{{/str}}</p>
    {{/has_records}}
</div>
<style>
.local_haccgen-timestamps .badge-draft { background-color: #6c757d; }
.local_haccgen-timestamps .badge-created { background-color: #28a745; }
</style>
